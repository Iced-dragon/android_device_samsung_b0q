# Graphics & Rendering Optimization
ro.hardware.egl=adreno
ro.hardware.gralloc=qcom
ro.opengles.version=196610
debug.sf.hw=1
debug.egl.hw=1

# Audio & Bluetooth Tweaks
ro.config.vc_call_vol=5
ro.bluetooth.library_version=bluetooth_qualcomm

# Radio / Telephony Core Profiles
telephony.lteOnCdmaDevice=1
ro.telephony.default_network=33
